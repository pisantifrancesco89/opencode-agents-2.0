{
  // OpenCode Configuration — AI Software House
  // Generated by Universal AI Software House setup
  //
  // ── HOW TO CONFIGURE MODELS ──
  // Change "model" at the top level for the default model.
  // Override per-agent in the "agent" section below.
  //
  // Available model formats:
  //   "openai/gpt-4o"                  → GPT-4o
  //   "openai/gpt-4o-mini"             → GPT-4o Mini (cheaper)
  //   "anthropic/claude-sonnet-4-20250514" → Claude Sonnet 4
  //   "anthropic/claude-haiku-3-5"     → Claude Haiku (cheaper)
  //
  // Temperature: 0.0 (deterministic) to 1.0 (creative)
  //   - Builder/Reviewer: 0.1-0.2 (precise code)
  //   - Orchestrator/Planner: 0.3-0.4 (balanced)
  //   - UI/Design: 0.3 (creative)

  "default_agent": "orchestrator",
  "model": "openai/gpt-4o",
  "small_model": "openai/gpt-4o-mini",
  "auto_apply": false,
  "skills": [
    "opencode-agents"
  ],
  "rules": [
    "Always read .memory/project.md before starting work",
    "Read .memory/errors.md to avoid known mistakes",
    "Read .memory/successes.md for patterns that work",
    "Read .memory/progress.md for current status",
    "Read .memory/decisions.md for architecture decisions",
    "After completing work, update all .memory/ files",
    "Use the orchestrator agent as the primary interface"
  ],

  // ── Per-Agent Model Configuration ──
  // Each sub-agent can use a different model and temperature.
  // The orchestrator using the `task` tool launches agents with these settings.
  "agent": {
    // CEO — plans, delegates, coordinates
    "orchestrator": {
      "model": "openai/gpt-4o",
      "temperature": 0.3
    },
    // Analysis & roadmaps (more creative)
    "planner": {
      "model": "openai/gpt-4o",
      "temperature": 0.4
    },
    // Code implementation (precise, safe)
    "builder": {
      "model": "openai/gpt-4o",
      "temperature": 0.2
    },
    // Code review (very deterministic)
    "reviewer": {
      "model": "openai/gpt-4o",
      "temperature": 0.1
    },
    // Documentation (clear, consistent)
    "documenter": {
      "model": "openai/gpt-4o",
      "temperature": 0.3
    },
    // Specialists (can use cheaper models)
    "ai-engineer": { "model": "openai/gpt-4o", "temperature": 0.2 },
    "auth-specialist": { "model": "openai/gpt-4o", "temperature": 0.2 },
    "backend-specialist": { "model": "openai/gpt-4o", "temperature": 0.2 },
    "data-specialist": { "model": "openai/gpt-4o", "temperature": 0.2 },
    "database-specialist": { "model": "openai/gpt-4o", "temperature": 0.2 },
    "devops-specialist": { "model": "openai/gpt-4o", "temperature": 0.2 },
    "frontend-specialist": { "model": "openai/gpt-4o", "temperature": 0.2 },
    "integration-specialist": { "model": "openai/gpt-4o", "temperature": 0.2 },
    "mobile-specialist": { "model": "openai/gpt-4o", "temperature": 0.2 },
    "payment-specialist": { "model": "openai/gpt-4o", "temperature": 0.2 },
    "performance-specialist": { "model": "openai/gpt-4o", "temperature": 0.2 },
    "qa-engineer": { "model": "openai/gpt-4o", "temperature": 0.1 },
    "realtime-specialist": { "model": "openai/gpt-4o", "temperature": 0.2 },
    "security-specialist": { "model": "openai/gpt-4o", "temperature": 0.1 },
    "testing-specialist": { "model": "openai/gpt-4o", "temperature": 0.1 },
    "ui-specialist": { "model": "openai/gpt-4o", "temperature": 0.3 }
  }
}
